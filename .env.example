# =========================================
# STARS HOMBRES - Variables de entorno
# Copiar este archivo a .env.local y completar
# =========================================

# --- BASE DE DATOS ---
# Opción A: PostgreSQL local
DATABASE_URL=postgresql://usuario:password@localhost:5432/stars_hombres

# Opción B: Neon (PostgreSQL serverless gratis)
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/stars_hombres?sslmode=require

# --- MERCADO PAGO ---
# Obtener en: https://www.mercadopago.com.ar/developers/panel/app
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxx

# --- JWT SECRET (cambiar por una cadena aleatoria larga) ---
JWT_SECRET=stars-hombres-jwt-secret-cambiame-2024

# --- SITIO ---
NEXT_PUBLIC_SITE_URL=https://starshombres.com.ar
# En desarrollo: http://localhost:3000

# --- WHATSAPP ---
# Formato: código de país + código de área + número SIN guiones NI espacios
# Ejemplo Córdoba: 5493516000000 (549 = Argentina + 351 = Córdoba + número)
NEXT_PUBLIC_WHATSAPP_NUMBER=5493516000000

# --- DATOS BANCARIOS (para transferencia) ---
NEXT_PUBLIC_BANK_NAME=Banco Galicia
NEXT_PUBLIC_BANK_CBU=0070123400000001234567
NEXT_PUBLIC_BANK_ALIAS=STARS.HOMBRES
NEXT_PUBLIC_BANK_HOLDER=Stars Hombres S.R.L.
NEXT_PUBLIC_BANK_CUIT=30-12345678-0
